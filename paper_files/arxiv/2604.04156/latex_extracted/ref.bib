file = {:Users/ssanyal3/Library/Application Support/Mendeley Desktop/Downloaded/Wuebbles et al. - 2014 - CMIP5 Climate Model Analyses Climate Extremes in the United States.pdf:pdf},
issn = {0003-0007},
journal = {Bulletin of the American Meteorological Society},
month = {apr},
