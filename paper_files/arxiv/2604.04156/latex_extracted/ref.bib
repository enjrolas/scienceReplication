@phdthesis{Sanyal2019,
abstract = {This dissertation focuses on understanding the complex interaction of air quality and climate change using a suit of global climate chemistry model simulation using Community Earth System Model (CESM). The first phase of the research uses the global model simulation to investigate long-range transport of pollutants from North America to Pico mountaintop observatory in the North Atlantic. HYSPLIT backward trajectories were then done to study airflow trajectories at PMO; these, show that more than 50{\%} of the air mass observed originated from North America. The model simulation was compared with the observation data at the site and high pollution events at Pico were correlated with boreal forest fires in North America. The results of this study indicate that the global model can well simulate the observed levels of these pollutants and can capture long-range transport events from North America. The result also confirmed that North American outflow is largely responsible for the high pollutant concentration events that have been measured at PMO. The second phase of the research looked into the impact of changing climate on air quality. This study examined exceedances for upper limits of exposure set by environmental policy. The fully coupled model of the Earth's climate system with interactive atmospheric chemistry was used in the study to examine exceedances for surface ozone and particulate matter (PM) concentrations for two different climate projections. The focus was on the United States, India and China. Along with an overall increase in ozone exceedances, the study also projected a significant shift in seasonality of the events. PM showed a significant increasing especially over China and India in the future with an overall increase of number of exceedance events annually in these two. The study also investigated a hypothetical clean energy scenario. The results showed that a switch to clean energy by mid-century greatly improve air quality.},
author = {Sanyal, Swarnali},
school = {University of Illinois at Urbana Champaign},
title = {{Evolving air quality and impact of climate change}},
url = {http://hdl.handle.net/2142/105049},
year = {2019}
}
@article{Wuebbles2015,
abstract = {{\textcopyright} 2015, Springer International Publishing AG (outside the USA). Two major environmental issues, air quality and climate change, are interlinked because of their large dependence on atmospheric emissions from human activities, especially from the burning of fossil fuels. Emission of air pollutants and heat trapping gases have greatly increased over the last five decades from our dependence throughout the world on conventional fossil fuel sources in production of electricity and in transportation systems, resulting in significant environmental issues with air quality and climate change throughout our planet. Future emissions of pollutants will depend on the choices made about our use of energy and transportation. The purpose of this study is to examine for now and into the future the relationship between energy production, the associated use of fossil fuels, and resulting effects on air pollution. In the process, we examine a clean energy future, imagined in this case for 2050, and then consider the resulting potential effects on air quality.},
author = {Wuebbles, D.J. and Sanyal, S.},
doi = {10.1007/s40726-015-0009-x},
issn = {21986592},
journal = {Current Pollution Reports},
keywords = {Air quality,Energy,Ozone,Particles},
number = {2},
title = {{Air Quality in a Cleaner Energy World}},
volume = {1},
year = {2015}
}
