@article{MacRae2025,
   abstract = {22 Background and Purpose: Deep learning (DL) outcome prediction models show promise in 23 radiotherapy but face limited clinical adoption due to concerns about prediction reliability. Although 24 uncertainty quantification (UQ) can provide confidence estimates alongside predictions, there is 25 currently little consensus on appropriate UQ methods and measures for DL-based outcome 26 prediction in radiotherapy. This study therefore evaluates and compares different UQ approaches for 27 normal tissue complication probability (NTCP) and tumour control probability (TCP) models in head 28 and neck cancer. 29 Materials and Methods: Four published DL models were reproduced: two NTCP models predicting 30 xerostomia and dysphagia at six months post-treatment, and two TCP models predicting two-year 31 survival and locoregional control. Three UQ methods-Monte Carlo dropout, deep ensembles, and 32 test-time augmentation-and three uncertainty measures-predictive entropy, variance, and mutual 33 information-were evaluated. Models were assessed on independent validation cohorts using 34 discriminative performance, calibration metrics, and sparsification analysis. 35 Results: Incorporating UQ maintained baseline predictive performance across all endpoints, with 36 occasional improvements. Deep ensembles and Monte Carlo dropout demonstrated strong 37 calibration between uncertainty values and prediction accuracy, while test-time augmentation 38 showed variable reliability. Entropy and variance consistently correlated with prediction accuracy, 39 whereas mutual information proved unstable. 40 Conclusions: Monte Carlo dropout and deep ensembles provide meaningful uncertainty estimates 41 for NTCP and TCP prediction without compromising model performance. These methods show 42 potential for selective prediction workflows where high-confidence predictions guide treatment 43 decisions while uncertain cases are flagged. 44 45},
   author = {DC MacRae and L van der Hoek and JE van Aalst and SPM de Vette and R van der Wal and Hendrike Neh and Baoqiang Ma and NM Sijtsema and MA Valdenegro-Toro and PMA van Ooijen and LV van Dijk},
   keywords = {NTCP,TCP 46,TCP Keywords: outcome prediction,deep learning,outcome prediction,uncertainty quantification},
   month = {12},
   title = {An Evaluation of Uncertainty Quantification Methods and Measures for Deep Learning Outcome Prediction Models in Head and Neck Cancer Radiotherapy},
   url = {https://ssrn.com/abstract=6041252},
   year = {2025}
}
